# Google AI Studio (Gemini)
GEMINI_API_KEY=buraya-gemini-api-keyin-gelecek
GEMINI_MODEL=gemini-2.5-flash

# Nöbetçi Eczane (CollectAPI)
COLLECT_API_KEY=buraya-collectapi-keyin-gelecek

# İlaç Arama Ayarları
DRUG_SEARCH_CACHE_TTL_SECONDS=86400
DRUG_SEARCH_RATE_LIMIT_WINDOW_SECONDS=60
DRUG_SEARCH_RATE_LIMIT_MAX_REQUESTS=10
DRUG_SEARCH_REDIS_ENABLED=True

# JWT — production'da güçlü rastgele bir değer kullanın (openssl rand -hex 32)
JWT_SECRET_KEY=buraya-guclu-bir-jwt-secret-gelecek
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=eczanem
POSTGRES_USER=eczanem_user
POSTGRES_PASSWORD=guclu-bir-sifre-belirleyin

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# API Ayarları
API_HOST=0.0.0.0
API_PORT=8000
# Production'da DEBUG=False olmalı; True iken /docs ve /redoc aktif olur
DEBUG=False

# CORS — production'da gerçek domain adresinizi girin
# Docker geliştirme ortamı için: http://10.0.2.2:8000
# Örnek: ALLOWED_ORIGINS=https://eczanem.app,https://www.eczanem.app
ALLOWED_ORIGINS=*
