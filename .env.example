# ─────────────────────────────────────────────────────────────────────────────
# Docker Compose — Ortam Değişkenleri Örneği
#
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env
#
# .env dosyası .gitignore tarafından takip dışı bırakılmıştır; asla commit etmeyin.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL (docker-compose.yml içindeki ${POSTGRES_*} değişkenlerini çözümler)
POSTGRES_DB=eczanem
POSTGRES_USER=eczanem_user
POSTGRES_PASSWORD=guclu-bir-sifre-belirleyin
